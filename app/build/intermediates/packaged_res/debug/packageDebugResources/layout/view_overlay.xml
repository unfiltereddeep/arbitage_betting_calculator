<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/overlayHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_title"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="@string/drag_label"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/overlayCloseButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/close_overlay"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/textPrimary" />
    </LinearLayout>

    <TextView
        android:id="@+id/overlayStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_status_neutral"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:text="@string/default_status"
        android:textColor="@color/textPrimary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/overlayBackOddsInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_overlay_input"
        android:hint="@string/back_odds"
        android:inputType="numberDecimal"
        android:maxLines="1"
        android:padding="12dp"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary" />

    <EditText
        android:id="@+id/overlayLayOddsInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_overlay_input"
        android:hint="@string/lay_odds"
        android:inputType="numberDecimal"
        android:maxLines="1"
        android:padding="12dp"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary" />

    <EditText
        android:id="@+id/overlayBackStakeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_overlay_input"
        android:hint="@string/back_stake"
        android:inputType="numberDecimal|numberSigned"
        android:maxLines="1"
        android:padding="12dp"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary" />

    <EditText
        android:id="@+id/overlayLayStakeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_overlay_input"
        android:hint="@string/lay_stake"
        android:inputType="numberDecimal|numberSigned"
        android:maxLines="1"
        android:padding="12dp"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/back_stake_result"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/overlayBackStakeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_value"
            android:textColor="@color/textPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lay_stake_result"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/overlayLayStakeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_value"
            android:textColor="@color/textPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profit_result"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/overlayProfitValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_value"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
